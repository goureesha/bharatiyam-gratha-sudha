rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Categories: anyone can read ──
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Books: anyone can read ──
    match /books/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Chapters: anyone can read ──
    match /chapters/{chapterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Shlokas: anyone can read ──
    match /shlokas/{shlokaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Config: anyone can read content version ──
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Users: users can read/write their own doc ──
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Helper functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['goureesha@gmail.com'];
    }
  }
}
